# Swiss Territory App — Environment Variables
# Copy this to .env and fill in your values.

# Admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
# Or provide a pre-hashed bcrypt password (preferred for production):
# ADMIN_PASSWORD_HASH=$2a$10$...

# Session secret (use a long random string in production)
SESSION_SECRET=replace-with-a-secure-random-string

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# CORS allowed origins (comma-separated, leave empty for same-origin only)
# ALLOWED_ORIGINS=https://your-domain.com
