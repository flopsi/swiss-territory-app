# Swiss Territory App — Environment Variables
# Copy this to .env and fill in your values.

# Admin credentials (full read/write access)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
# Or provide a pre-hashed bcrypt password (preferred for production):
# ADMIN_PASSWORD_HASH=$2a$10$...

# View-only management user (can inspect but not modify data)
VIEWER_USER=viewer
VIEWER_PASSWORD=viewonly
# Or provide a pre-hashed bcrypt password (preferred for production):
# VIEWER_PASSWORD_HASH=$2a$10$...

# Session secret (use a long random string in production)
SESSION_SECRET=replace-with-a-secure-random-string

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# CORS allowed origins (comma-separated, leave empty for same-origin only)
# ALLOWED_ORIGINS=https://your-domain.com

# --- Vercel-specific ---
# VERCEL is set automatically by Vercel; do not set manually.
# Required Vercel Environment Variables:
#   ADMIN_USER, ADMIN_PASSWORD_HASH, SESSION_SECRET, NODE_ENV=production
#   BLOB_READ_WRITE_TOKEN  (from Vercel Blob store — required for durable persistence)

# Vercel Blob token (enables durable excluded-ZIP and dataset persistence on Vercel)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
